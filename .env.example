# === VAPI ===
VAPI_API_KEY=your_vapi_private_key_from_dashboard
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
VAPI_SECRET=your_shared_webhook_secret
VAPI_KB_ID=your_vapi_knowledge_base_id

# === n8n Cloud ===
N8N_API_KEY=your_n8n_api_key
N8N_WEBHOOK_BASE_URL=https://your-instance.app.n8n.cloud

# === Supabase ===
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# n8n Cloud uses the built-in Supabase node (REST API credential):
# Host: https://your-project-ref.supabase.co
# Service Role Key: (same as above)

# === FastAPI ===
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
