      "parameters": {
        "jsCode": "const body = $('Webhook').first().json.body;\nconst toolCallId = body.message?.toolCallList?.[0]?.id || body.message?.toolCalls?.[0]?.id || '';\nreturn [{\n  json: {\n    results: [{\n      toolCallId,\n      result: JSON.stringify({ success: false, error: 'Failed to save interaction record' })\n    }]\n  }\n}];"
      },
      "id": "fmt-err",
