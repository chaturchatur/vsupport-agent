    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst message = body.message;\nconst vapiCallId = message.call?.id || '';\nconst toolCall = message.toolCallList?.[0] || {};\nconst args = toolCall.function?.arguments || {};\n\nconst validSentiments = ['positive', 'neutral', 'negative'];\nconst sentiment = validSentiments.includes(args.sentiment) ? args.sentiment : 'neutral';\n\nreturn [{\n  json: {\n    caller_name: (args.caller_name || 'Unknown').trim(),\n    phone_number: (args.phone_number || '').trim(),\n    summary: (args.summary || '').trim(),\n    sentiment,\n    timestamp: new Date().toISOString(),\n    vapi_call_id: vapiCallId\n  }\n}];"
      },
      "id": "parse-log",
      "name": "Parse Envelope",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 0]
    },
    {
      "parameters": {
        "operation": "create",
        "tableId": "interactions",
        "dataToSend": "autoMapInputData"
      },
      "id": "sb-insert",
      "name": "Insert Interaction",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [440, 0],
      "onError": "continueErrorOutput",
      "credentials": {
        "supabaseApi": {
          "id": "Zhs4bVeCvuPXCQkF",
          "name": "Supabase account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const body = $('Webhook').first().json.body;\nconst toolCallId = body.message?.toolCallList?.[0]?.id || body.message?.toolCalls?.[0]?.id || '';\nconst result = $input.first().json;\nreturn [{\n  json: {\n    results: [{\n      toolCallId,\n      result: JSON.stringify({ success: true, record_id: result.id || 'unknown' })\n    }]\n  }\n}];"
      },
      "id": "fmt-ok",
      "name": "Format Success",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, -60]
    },
